# Copy this file to .env for local development only.
# Never commit real .env files. In production, inject secrets from the
# deployment platform or a managed secret store.

# ─── 基础 ─────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development
PROJECT_NAME=Kenne Index

# ─── 数据库 ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-local-password
POSTGRES_DB=kenne_main
DATABASE_URL=postgresql+asyncpg://postgres:change-this-local-password@localhost:5432/kenne_main
# 多租户数据库 URL 模板（{tenant_id} 会被替换）
TENANT_DB_URL_TEMPLATE=postgresql+asyncpg://postgres:change-this-local-password@localhost:5432/kenne_tenant_{tenant_id}

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# auto 优先 Redis，不可用时降级内存；也可设为 memory
RATE_LIMIT_BACKEND=auto

# ─── JWT ──────────────────────────────────────────────────
# Required in production. Use a high-entropy random value.
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# 本地开发使用 false，生产 HTTPS 环境应设置为 true
COOKIE_SECURE=false
CSRF_PROTECTION=true
# Global emergency switch for live order placement. Keep true only when the
# production environment is ready for real trading.
GLOBAL_LIVE_TRADING_ENABLED=true

# ─── 系统邮件（账号验证、忘记密码、安全提醒）────────────
# 用户自己的 SMTP 只用于投资报告；账号安全邮件使用以下系统 SMTP。
SYSTEM_SMTP_HOST=
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=
SYSTEM_SMTP_PASSWORD=
SYSTEM_SMTP_FROM=

# ─── 加密密钥（用于加密存储 API Key 等敏感信息）─────────
# Required in production. Keep stable after first deploy or encrypted API keys
# will no longer decrypt. Rotate with a planned data migration.
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ─── 行情 / 研究 API（可选，按功能启用）──────────────────
COINGECKO_API_KEY=
GLASSNODE_API_KEY=
RESEARCHBITCOIN_API_TOKEN=

# ─── CORS ─────────────────────────────────────────────────
# Production must list only trusted HTTPS origins.
CORS_ORIGINS=["http://localhost:5173"]

# ─── Stripe（付费系统）────────────────────────────────────
# Required when billing is enabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# ─── 自定义回测 ───────────────────────────────────────────
# 服务器本地路径回测只允许读取 DATA_DIR 和 BACKTEST_ALLOWED_DIRS 内的 CSV。
# 示例 Windows: BACKTEST_ALLOWED_DIRS=["E:/AHR999-Optimized-Kenne-Index-main/backend/data"]
DATA_DIR=./data
BACKTEST_ALLOWED_DIRS=[]

# ─── Hermes Agent Webhook（可选）──────────────────────────
# If set, use a secret generated specifically for this webhook and rotate it
# if it has ever appeared in logs, screenshots, commits, or shared archives.
HERMES_WEBHOOK_URL=
HERMES_WEBHOOK_SECRET=

# ─── 告警系统（可选）───────────────────────────────────────
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_DISCORD_WEBHOOK_URL=
# 系统级告警接收邮箱
SYSTEM_ALERT_RECIPIENT=
